# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional app links
EXPO_PUBLIC_WHATSAPP_GROUP_URL=
EXPO_PUBLIC_YOUTUBE_CHANNEL_URL=
EXPO_PUBLIC_DEFAULT_ZOOM_LINK=
EXPO_PUBLIC_CONTACT_EMAIL=
EXPO_PUBLIC_AUTH_REDIRECT_URL=sacredcircle://auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payments are optional in V1. Never expose Razorpay secret keys in frontend apps.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Push sending requires platform setup outside this scaffold.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Server-side only: Cloudflare R2 for audio/media signed URLs.
# Do not expose R2 access keys in Expo or browser bundles.
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=audio
